{
  "name": "@iplex/aicut-vue",
  "version": "0.7.5",
  "description": "Vue 3 wrapper for the AiCut video editor + lighting picker — thin declarative shells over @iplex/aicut-core.",
  "license": "MIT",
  "author": "ziqiang <ziqiangytu@gmail.com>",
  "homepage": "https://github.com/ipmotionmc/AiCut#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ipmotionmc/AiCut.git",
    "directory": "packages/vue"
  },
  "bugs": {
    "url": "https://github.com/ipmotionmc/AiCut/issues"
  },
  "keywords": [
    "video-editor",
    "video-editing",
    "vue",
    "vue3",
    "vue-component",
    "timeline",
    "timeline-editor",
    "nle",
    "video-cutter",
    "video-clip",
    "canvas",
    "video",
    "editor",
    "mp4",
    "component",
    "capcut",
    "premiere",
    "final-cut",
    "davinci",
    "imovie",
    "veed",
    "filmora",
    "lighting",
    "three.js"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./lighting": {
      "types": "./dist/lighting.d.ts",
      "import": "./dist/lighting.js",
      "require": "./dist/lighting.cjs"
    },
    "./webcodecs": {
      "types": "./dist/webcodecs.d.ts",
      "import": "./dist/webcodecs.js",
      "require": "./dist/webcodecs.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "vite build && vue-tsc --emitDeclarationOnly -p tsconfig.json --outDir dist",
    "dev": "vite build --watch",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@iplex/aicut-core": "workspace:*"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vue": "^3.5.13",
    "vue-tsc": "^2.1.10"
  },
  "publishConfig": {
    "registry": "https://iplex-883218392300.d.codeartifact.us-west-2.amazonaws.com/npm/iplex-npm/"
  }
}
