auto-install-peers=true
strict-peer-dependencies=false
shamefully-hoist=false
prefer-workspace-packages=true

# @iplex scope → private AWS CodeArtifact (publish target). Only this scope is
# routed; the default registry stays npmjs so all public deps install normally.
# The auth token is injected at publish time via ${NODE_AUTH_TOKEN}, which CI
# mints from the AWS OIDC role. Local dev needs no token: this repo only
# PUBLISHES the @iplex scope, it never installs from it (internal deps are
# workspace-resolved).
@iplex:registry=https://iplex-883218392300.d.codeartifact.us-west-2.amazonaws.com/npm/iplex-npm/
//iplex-883218392300.d.codeartifact.us-west-2.amazonaws.com/npm/iplex-npm/:_authToken=${NODE_AUTH_TOKEN}
//iplex-883218392300.d.codeartifact.us-west-2.amazonaws.com/npm/iplex-npm/:always-auth=true
